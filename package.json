{
  "name": "framemodelmaker-web",
  "version": "1.1.0",
  "description": "Browser-based editor, validator, visualizer, and interchange tool for 3D frame analysis models",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit": "npm audit --audit-level=high",
    "typecheck": "tsc --noEmit -p tsconfig.check.json"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "keywords": [
    "structural-engineering",
    "frame-model",
    "three.js",
    "finite-element"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "three": "^0.185.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "@types/node": "^26.1.1",
    "@types/three": "^0.185.1",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
